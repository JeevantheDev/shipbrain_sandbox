{
  "name": "shipbrain-sandbox",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node server.mjs",
    "build": "mkdir -p dist && cp index.html dist/ && cp -r api dist/ 2>/dev/null || true",
    "test": "echo 'No tests configured' && exit 0",
    "vercel:pull": "vercel pull --yes --environment=production",
    "vercel:build": "vercel build --prod",
    "vercel:deploy:prod": "vercel deploy --prebuilt --prod"
  }
}
